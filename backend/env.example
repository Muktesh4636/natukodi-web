# Django Settings
DEBUG=False
SECRET_KEY=generate-a-strong-secret-key-here

# Single source of truth for public domain (HTTPS). Canonical host for this deployment:
PUBLIC_SITE_URL=https://svs.fightening.sbs
# If nginx also proxies apex/www here, add origins for CSRF (comma-separated):
# PUBLIC_SITE_EXTRA_ORIGINS=https://fightening.sbs,https://www.fightening.sbs

# Hostnames Django accepts (comma-separated). Must match the Host header nginx sends (usually svs.fightening.sbs).
# Add fightening.sbs or IP only if those hosts also hit this same app:
ALLOWED_HOSTS=svs.fightening.sbs

# Production merges svs.fightening.sbs / fightening.sbs / www automatically unless you disable:
# DISABLE_BUILTIN_ALLOWED_HOSTS=1

# If you still get HTTP 400 from Django, temporarily set (then fix nginx Host / ALLOWED_HOSTS and unset):
# DJANGO_ALLOW_ANY_HOST=1

# Only if your reverse proxy sets X-Forwarded-Host correctly and you need it:
# USE_X_FORWARDED_HOST=True

# Optional overrides (merged with defaults + PUBLIC_SITE_*):
# CSRF_TRUSTED_ORIGINS=https://other-origin.com
# CORS_ALLOWED_ORIGINS=https://svs.fightening.sbs

# Database Configuration
USE_SQLITE=False
DB_NAME=dice_game
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
REDIS_POOL_SIZE=50

