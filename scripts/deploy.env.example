# Copy to deploy.env (gitignored) and fill in DEPLOY_PASSWORD if you use password auth.
#
#   cp scripts/deploy.env.example scripts/deploy.env
#
# Never commit deploy.env.

DEPLOY_USER=root
DEPLOY_HOST=72.61.148.117
DEPLOY_REMOTE_PATH=/root/fight

# Password auth (requires `sshpass` on your machine: brew install hudochenkov/sshpass/sshpass)
# Use single quotes if the password contains # or special characters:
# DEPLOY_PASSWORD='your-password-here'

# Optional: systemd unit to restart after deploy (empty to skip)
DEPLOY_SYSTEMD_SERVICE=fight
