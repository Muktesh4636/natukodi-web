# Copy to deploy.env (gitignored) and fill in DEPLOY_PASSWORD if you use password auth.
#
#   cp scripts/deploy.env.example scripts/deploy.env
#
# Never commit deploy.env.

# Production Django env on the server (e.g. /root/fight/.env) for svs.fightening.sbs:
#   PUBLIC_SITE_URL=https://svs.fightening.sbs
#   ALLOWED_HOSTS=svs.fightening.sbs
# Then: systemctl restart fight

DEPLOY_USER=root
DEPLOY_HOST=72.61.148.117
DEPLOY_REMOTE_PATH=/root/fight

# Password auth (requires `sshpass` on your machine: brew install hudochenkov/sshpass/sshpass)
# Use single quotes if the password contains # or special characters:
# DEPLOY_PASSWORD='your-password-here'

# Optional: systemd unit to restart after deploy (empty to skip)
DEPLOY_SYSTEMD_SERVICE=fight

# Optional: Kokoroko browser SPA docroot — rsyncs kokoroko-web/index.html + app.js (Promotion → Referral & Earn).
# Example: DEPLOY_WEB_ROOT=/var/www/html
# DEPLOY_WEB_ROOT=

# --- Referral commission (daily 01:00 IST) ---
# On the server, add a cron entry so losses are settled once per night. Default command targets
# ``yesterday`` in TIME_ZONE (Asia/Kolkata). Example (adjust paths / venv):
#
#   CRON_TZ=Asia/Kolkata
#   0 1 * * * cd /root/fight && ./venv/bin/python manage.py process_referral_daily_commission >> /var/log/referral_commission.log 2>&1
#
# If your host cron has no CRON_TZ, install cron in IST or convert 01:00 IST to your server clock.
